# Required: Alpaca API credentials
ALPACA_API_KEY=
ALPACA_SECRET_API_KEY=

# Optional: Data feed (iex = free tier, sip = paid tier)
ALPACA_FEED=sip

# Optional: Override Alpaca WebSocket endpoint URL (defaults to wss://stream.data.alpaca.markets/v2/{feed})
# ALPACA_ENDPOINT_URL=

# Optional: Local proxy port
PROXY_PORT=8765

# Optional: Logging verbosity (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
